{
  "name": "@pool/product",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "workspaces": [
    "apps/*",
    "services/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm --workspace services/api run dev",
    "dev:web": "npm --workspace apps/web-react run dev",
    "dev:electron": "npm --workspace apps/electron run dev",
    "build:web": "npm --workspace apps/web-react run build",
    "build:electron": "npm --workspace apps/electron run build",
    "bootstrap:project": "node scripts/bootstrap-project.mjs",
    "demo:live": "node scripts/demo-live-flow.mjs",
    "verify:mvp": "node scripts/verify-mvp-live.mjs",
    "start": "npm --workspace services/api run start",
    "start:web": "npm --workspace apps/web-react run preview",
    "start:electron": "npm --workspace apps/electron run start",
    "check": "npm run build:web && node scripts/check-types.mjs",
    "check:electron": "npm --workspace apps/electron run check",
    "check:ui": "npm run build:web && node scripts/check-react-ui-browser.mjs",
    "test": "node --test"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@radix-ui/react-dialog": "^1.1.16",
    "@radix-ui/react-tabs": "^1.1.14",
    "@radix-ui/react-tooltip": "^1.2.9",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "lucide-react": "^1.17.0",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "typescript": "^5.9.3",
    "vite": "^7.2.7"
  }
}
