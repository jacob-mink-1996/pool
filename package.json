{
  "name": "@pool/product",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "workspaces": [
    "apps/*",
    "services/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm --workspace services/api run dev",
    "dev:web": "npm --workspace apps/web run dev",
    "bootstrap:project": "node scripts/bootstrap-project.mjs",
    "demo:live": "node scripts/demo-live-flow.mjs",
    "verify:mvp": "node scripts/verify-mvp-live.mjs",
    "start": "npm --workspace services/api run start",
    "start:web": "npm --workspace apps/web run start",
    "check": "node scripts/check-types.mjs",
    "test": "node --test"
  }
}
